# Base de la API. En Vercel ponlo a "/api" (funciones serverless en el mismo
# dominio → R2 para ficheros, Neon para pedidos/catálogo). Vacío = modo local
# (IndexedDB + localStorage, un solo navegador) para desarrollo/demo sin backend.
VITE_API_BASE=

# --- Solo en el SERVIDOR (Vercel Environment Variables), nunca con prefijo VITE_ ---
# Estas NO van en el bundle del cliente. Las leen las funciones de /api.
#   R2_ACCESS_KEY_ID=...        (secreto del token R2)
#   R2_SECRET_ACCESS_KEY=...    (secreto del token R2)
#   R2_ACCOUNT_ID=...           (opcional; por defecto el del proyecto)
#   R2_BUCKET=copyvending       (opcional)
#   DATABASE_URL=...            (la añade sola la integración de Neon)
#
# --- Ingesta por email (/api/ingest-email), solo SERVIDOR ---
#   GMAIL_USER=copyvending@gmail.com       (la cuenta del buzón; modificable)
#   GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx     (contraseña de aplicación, 16 car.)
#   PUBLIC_URL=https://copyvending.vercel.app  (opcional; enlaces de respuesta/acceso a cuenta)
#   SHOP_NAME=Copistería                   (opcional; nombre en los emails: bienvenida, acceso…)
#
# --- Asistente IA (/api/assistant), solo SERVIDOR ---
#   GROQ_API_KEY=...            (gratis en console.groq.com)
# Provider-agnostic (opcionales, para cambiar de modelo sin tocar código):
#   LLM_BASE_URL=...            (por defecto https://api.groq.com/openai/v1)
#   LLM_API_KEY=...             (por defecto GROQ_API_KEY)
#   LLM_MODEL=...               (por defecto llama-3.3-70b-versatile)
#   STT_MODEL=...               (transcripción de voz; por defecto whisper-large-v3-turbo)
